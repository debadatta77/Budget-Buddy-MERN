# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/budgetbuddy
# Or use MongoDB Atlas connection string:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/budgetbuddy?retryWrites=true&w=majority

# JWT Secret Key (Generate a strong random string for production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# Or use your actual frontend URL:
# FRONTEND_URL=https://your-frontend-host.vercel.app
